#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOGFILE="$SCRIPT_DIR/mail.log"

"$SCRIPT_DIR/fasttail" --daemon --logfile "$LOGFILE" --backfill 20 &
DAEMON_PID=$!

cleanup() {
    kill "$DAEMON_PID" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

# Wait for the backfill to land before tailing
sleep 2

tail -f "$LOGFILE"
